import { useState, useEffect, useRef } from "react";
import { useParams, Link, useNavigate } from "react-router-dom";
import {
  ArrowLeft,
  BookOpen,
  Building2,
  CheckCircle,
  ClipboardCheck,
  Droplets,
  FlaskConical,
  GraduationCap,
  Home,
  Layers,
  MapPin,
  Monitor,
  Phone,
  Sun,
  Target,
  TeacherIcon,
  Trophy,
  TrendingUp,
  Activity,
  AlertTriangle,
  Users,
  Utensils,
  Wrench,
  XCircle,
  Zap,
  Wifi,
  Box,
  ChevronRight,
  Clock,
  Globe,
  Image,
  Mail,
  Upload,
  MapIcon,
} from "lucide-react";
import { Button } from "../components/ui/button";
import { Badge } from "../components/ui/badge";
import { Card, CardContent, CardHeader, CardTitle } from "../components/ui/card";
import { PageHeader } from "../components/ui/page-header";
import { motion } from "framer-motion";
import { cn } from "../lib/utils";
import { api } from "../lib/api";
import { SchoolForm } from "../components/SchoolForm";
import { FacilitySurveyForm } from "../components/FacilitySurveyForm";

type BuildingCondition = "good" | "fair" | "poor" | "critical";
type PriorityLevel = "critical" | "high" | "medium" | "low";

export default function SchoolDecisionDashboard() {
  const { id } = useParams<{ id: string }>();
  const navigate = useNavigate();
  const [school, setSchool] = useState<any>(null);
  const [loading, setLoading] = useState(true);
  const [is3DViewOpen, setIs3DViewOpen] = useState(false);
  const [isEditModalOpen, setIsEditModalOpen] = useState(false);
  const [isSurveyModalOpen, setIsSurveyModalOpen] = useState(false);
  const [facilitySurvey, setFacilitySurvey] = useState<any[]>([]);
  const [facilitiesList, setFacilitiesList] = useState<any[]>([]);

  const lastFetchedId = useRef<string | null>(null);

  useEffect(() => {
    if (!id) return;
    if (lastFetchedId.current === id) return;

    const fetchSchool = async () => {
      setLoading(true);
      try {
        // Fetch school (buildings, assessments included by default)
        const response = await api.get(`/schools/${id}`);
        const schoolData = response.data;

        // Calculate dynamic assessment data - do calculation even without buildings
        if (
          schoolData.buildings ||
          schoolData.educationPrograms ||
          schoolData.roadStatusPercentage
        ) {
          const currentYear = new Date().getFullYear();

          // Calculate average building age (if buildings exist)
          let avgBuildingAge = 0;
          let totalDepreciation = 0;
          let buildingAgeScore = 50;

          if (schoolData.buildings && schoolData.buildings.length > 0) {
            const buildingAges = schoolData.buildings
              .filter((b: any) => b.yearBuilt)
              .map((b: any) => currentYear - b.yearBuilt);
            avgBuildingAge =
              buildingAges.length > 0
                ? Math.round(
                    buildingAges.reduce((a: number, b: number) => a + b, 0) /
                      buildingAges.length,
                  )
                : 0;

            // Calculate depreciation based on age and condition
            // Standard depreciation: 2% per year, max 60%
            // Condition adjustments: good=0, fair=10%, poor=20%, critical=30%
            const conditionPenalties: Record<string, number> = {
              good: 0,
              fair: 10,
              poor: 20,
              critical: 30,
            };

            const avgConditionPenalty =
              schoolData.buildings.reduce((sum: number, b: any) => {
                return sum + (conditionPenalties[b.condition] || 10);
              }, 0) / schoolData.buildings.length;

            const ageDepreciation = Math.min(avgBuildingAge * 2, 60);
            totalDepreciation = Math.min(
              ageDepreciation + avgConditionPenalty,
              100,
            );

            buildingAgeScore = Math.max(0, 100 - totalDepreciation);
          }

          // Infrastructure: calculate average of all infrastructure items
          // Boolean facilities convert to 100 if present, 0 if not
          const infrastructureItems = [
            schoolData.hasLibrary ? 100 : 0,
            schoolData.hasLaboratory ? 100 : 0,
            schoolData.hasComputerLab ? 100 : 0,
            schoolData.hasSportsField ? 100 : 0,
            schoolData.hasHostel ? 100 : 0,
            schoolData.hasCanteen ? 100 : 0,
            schoolData.hasElectricity ? 100 : 0,
            schoolData.hasWater ? 100 : 0,
            schoolData.hasInternet ? 100 : 0,
            schoolData.hasSolarPanel ? 100 : 0,
            schoolData.roadStatusPercentage || 50,
          ];
          const infrastructureScore = Math.round(
            infrastructureItems.reduce((a, b) => a + b, 0) /
              infrastructureItems.length,
          );

          // Calculate population: students from trades + staff
          const totalStudentsInPrograms =
            schoolData.educationPrograms?.reduce(
              (sum: number, p: any) => sum + (p.totalStudents || 0),
              0,
            ) || 0;
          const totalStaff =
            (schoolData.maleTeachers || 0) +
            (schoolData.femaleTeachers || 0) +
            (schoolData.adminStaff || 0) +
            (schoolData.supportStaff || 0);
          const totalPopulation = totalStudentsInPrograms + totalStaff;

          // Total capacity from trades
          const totalCapacity =
            schoolData.educationPrograms?.reduce(
              (sum: number, p: any) => sum + (p.capacity || 0),
              0,
            ) || 0;

          // Population: students from trades (not staff)
          // For scoring: use students capacity utilization (students / capacity)
          const populationScore =
            totalCapacity > 0 && totalStudentsInPrograms > 0
              ? Math.min(
                  100,
                  Math.round((totalStudentsInPrograms / totalCapacity) * 100),
                )
              : 50;

          // Population pressure for display (capacity utilization)
          const populationPressure = populationScore;

          // Accessibility: use roads status percentage
          const accessibilityScore = schoolData.roadStatusPercentage || 50;

          // Calculate overall score as simple average of all 4 components
          const overallScore = Math.round(
            (infrastructureScore +
              buildingAgeScore +
              populationScore +
              accessibilityScore) /
              4,
          );

          // Add calculated assessment to school data
          schoolData.calculatedAssessment = {
            infrastructureScore: infrastructureScore,
            buildingAgeScore: buildingAgeScore,
            depreciation: totalDepreciation,
            populationPressureScore: populationPressure,
            accessibilityScore: accessibilityScore,
            overallScore: overallScore,
            averageBuildingAge: avgBuildingAge,
            totalCapacity: totalCapacity,
            totalStudents: totalStudentsInPrograms,
            totalStaff: totalStaff,
            totalPopulation: totalPopulation,
          };
        }

        setSchool({ ...schoolData });

        // Fetch facility survey data if school exists
        if (id) {
          try {
            const surveyRes = await api.get(`/schools/${id}/survey`);
            setFacilitySurvey(surveyRes.data || []);
          } catch (surveyError) {
            console.log("No facility survey found for this school");
            setFacilitySurvey([]);
          }

          // Also fetch facilities list for displaying facility names
          try {
            const facilitiesRes = await api.get("/schools/facilities");
            setFacilitiesList(facilitiesRes.data || []);
          } catch (facilitiesError) {
            console.log("No facilities found");
            setFacilitiesList([]);
          }
        }
      } catch (error) {
        console.error("Failed to fetch school data", error);
      } finally {
        setLoading(false);
      }
    };

    lastFetchedId.current = id;
    fetchSchool();
  }, [id]);

  // Merge real data with dummy data structure
  const schoolData = school;

  // Calculate derived values from trades (real data)
  const educationPrograms = schoolData?.educationPrograms || [];
  const totalStudents =
    educationPrograms.length > 0
      ? educationPrograms.reduce(
          (sum: number, p: any) => sum + (p.totalStudents || 0),
          0,
        )
      : 0;

  const totalCapacity =
    educationPrograms.length > 0
      ? educationPrograms.reduce(
          (sum: number, p: any) => sum + (p.capacity || 0),
          0,
        )
      : 0;

  // All staff (teachers + admin + support)
  const maleTeachers = schoolData?.maleTeachers ?? 0;
  const femaleTeachers = schoolData?.femaleTeachers ?? 0;
  const adminStaff = schoolData?.adminStaff ?? 0;
  const supportStaff = schoolData?.supportStaff ?? 0;
  const totalTeachers = maleTeachers + femaleTeachers;
  const totalStaff = totalTeachers + adminStaff + supportStaff;

  // Facility survey calculations
  const getFacilitySurveyStats = () => {
    if (!facilitySurvey || facilitySurvey.length === 0) {
      return {
        compliant: 0,
        partial: 0,
        nonCompliant: 0,
        total: 0,
        complianceRate: 0,
        byFacility: [],
      };
    }

    const compliant = facilitySurvey.filter(
      (s: any) => s.compliance === "compliant",
    ).length;
    const partial = facilitySurvey.filter(
      (s: any) => s.compliance === "partial",
    ).length;
    const nonCompliant = facilitySurvey.filter(
      (s: any) => s.compliance === "non_compliant",
    ).length;
    const total = facilitySurvey.length;
    const complianceRate =
      total > 0 ? Math.round((compliant / total) * 100) : 0;

    // Group by facilityId for detailed breakdown
    const byFacilityMap: Record<string, { facility: string; items: any[] }> =
      {};
    facilitySurvey.forEach((survey: any) => {
      if (!byFacilityMap[survey.facilityId]) {
        const facilityInfo = facilitiesList.find(
          (f: any) => f.facilityId === survey.facilityId,
        );
        byFacilityMap[survey.facilityId] = {
          facility: facilityInfo?.title || survey.facilityId,
          items: [],
        };
      }
      // Find item name
      const facilityInfo = facilitiesList.find(
        (f: any) => f.facilityId === survey.facilityId,
      );
      const itemInfo = facilityInfo?.items?.find(
        (i: any) => i.id === survey.itemId,
      );
      byFacilityMap[survey.facilityId].items.push({
        ...survey,
        itemName: itemInfo?.label || survey.itemId,
      });
    });

    return {
      compliant,
      partial,
      nonCompliant,
      total,
      complianceRate,
      byFacility: Object.values(byFacilityMap),
    };
  };

  const facilityStats = getFacilitySurveyStats();

  const buildings = schoolData?.buildings || [];

  // Calculate average building year
  const buildingsWithYear = buildings.filter((b: any) => b.yearBuilt);
  const avgBuildingYear =
    buildingsWithYear.length > 0
      ? Math.round(
          buildingsWithYear.reduce(
            (sum: number, b: any) => sum + b.yearBuilt,
            0,
          ) / buildingsWithYear.length,
        )
      : 0;

  // Calculate priority level based on Building Condition and Roof Condition
  const getPriorityFromBuildings = () => {
    if (!buildings || buildings.length === 0) return "medium";

    const conditionScores: Record<string, number> = {
      good: 0,
      fair: 25,
      poor: 50,
      critical: 75,
    };
    const roofScores: Record<string, number> = {
      good: 0,
      needs_repair: 15,
      damaged: 35,
    };

    const avgBuildingScore =
      buildings.reduce((sum: number, b: any) => {
        return sum + (conditionScores[b.condition] || 25);
      }, 0) / buildings.length;

    const avgRoofScore =
      buildings.reduce((sum: number, b: any) => {
        return sum + (roofScores[b.roofCondition] || 15);
      }, 0) / buildings.length;

    const totalScore = avgBuildingScore + avgRoofScore;

    if (totalScore >= 75) return "critical";
    if (totalScore >= 50) return "high";
    if (totalScore >= 25) return "medium";
    return "low";
  };

  const priorityLevel = getPriorityFromBuildings();

  // Use calculated assessment from real data, or fallback to API assessment, or dummy data
  const getAssessment = () => {
    if (schoolData?.calculatedAssessment) {
      return {
        ...schoolData.calculatedAssessment,
        // Use building/roof condition-based priority level instead of score-based
        priorityLevel: priorityLevel,
        recommendations: [
          schoolData.calculatedAssessment.depreciation > 40
            ? "Consider building renovation due to high depreciation"
            : null,
          schoolData.calculatedAssessment.populationPressureScore > 80
            ? "Population pressure is high - consider expansion"
            : null,
          schoolData.calculatedAssessment.infrastructureScore < 50
            ? "Infrastructure needs immediate attention"
            : null,
        ].filter(Boolean),
        estimatedBudgetRwf:
          schoolData.calculatedAssessment.depreciation * 5000000,
        urgencyMonths: Math.max(
          1,
          Math.round((100 - schoolData.calculatedAssessment.overallScore) / 10),
        ),
      };
    }
    if (schoolData?.assessments && schoolData.assessments.length > 0) {
      const latestAssessment = schoolData.assessments[0];
      return {
        ...latestAssessment,
        depreciation: Math.round(
          100 - (latestAssessment.buildingAgeScore || 50),
        ),
        priorityLevel: priorityLevel,
      };
    }
    return {
      priorityLevel: priorityLevel,
    };
  };

  const assessment = getAssessment();

  const getPriorityBadge = (priority: PriorityLevel | string) => {
    switch (priority) {
      case "critical":
        return (
          <Badge
            variant="destructive"
            className="rounded-full font-black text-xs"
          >
            CRITICAL
          </Badge>
        );
      case "high":
        return (
          <Badge className="rounded-full font-black text-xs bg-amber-500 hover:bg-amber-600">
            HIGH
          </Badge>
        );
      case "medium":
        return (
          <Badge variant="outline" className="rounded-full font-black text-xs">
            MEDIUM
          </Badge>
        );
      case "low":
        return (
          <Badge className="rounded-full font-black text-xs bg-emerald-500 hover:bg-emerald-600">
            LOW
          </Badge>
        );
      default:
        return (
          <Badge variant="outline" className="rounded-full font-black text-xs">
            N/A
          </Badge>
        );
    }
  };

  const formatNumber = (num: number | undefined | null) => {
    if (num === undefined || num === null) return "--";
    return new Intl.NumberFormat("en-US").format(num);
  };

  if (loading) {
    return (
      <div className="p-8 flex flex-col items-center justify-center min-h-[400px] space-y-4">
        <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-primary"></div>
        <p className="text-xs font-black uppercase tracking-widest animate-pulse text-muted-foreground">
          Loading Decision Intelligence...
        </p>
      </div>
    );
  }

  if (!schoolData) {
    return (
      <div className="p-8 flex flex-col items-center justify-center min-h-[400px] space-y-4 text-center">
        <AlertTriangle className="w-16 h-16 text-destructive/50 mb-2" />
        <h2 className="text-2xl font-bold">School Not Found</h2>
        <p className="text-muted-foreground text-sm">
          The school could not be loaded.
        </p>
        <Button asChild className="rounded-full mt-4" variant="outline">
          <Link to="/schools">Return to Directory</Link>
        </Button>
      </div>
    );
  }

  // Use the values already computed above

  return (
    <>
      {!isSurveyModalOpen && (
        <div className="space-y-6 pb-10">
          {/* Header */}
          <PageHeader
            backButton={
              <Button
                variant="outline"
                size="icon"
                asChild
                className="rounded-full h-12 w-12 border-border/10 hover:bg-background/50 hover:border-primary/30 transition-all shadow-none"
              >
                <Link to="/schools">
                  <ArrowLeft className="h-5 w-5" />
                </Link>
              </Button>
            }
            title={schoolData.name}
            titleBadge={
              <div className="flex items-center gap-2">
                <Badge
                  variant="outline"
                  className="rounded-full uppercase text-[10px] font-black px-3 py-0.5 border-primary/20 text-primary bg-primary/5 shadow-none"
                >
                  {schoolData.type}
                </Badge>
                <span className="text-[10px] font-black text-muted-foreground/40 uppercase tracking-widest">
                  ID: {schoolData.code}
                </span>
              </div>
            }
            description={
              <span className="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-muted-foreground/60">
                <Globe className="w-3.5 h-3.5 text-primary/40" />
                {schoolData.province} • {schoolData.district} •{" "}
                {schoolData.sector}
              </span>
            }
            actions={
              <div className="flex flex-wrap items-center gap-2">
                {(schoolData.buildings?.some((b: any) => b.modelPath) ||
                  schoolData.kmzFilePath) && (
                  <Button
                    variant="outline"
                    onClick={() => id && navigate(`/schools/${id}/3dview`)}
                    className="rounded-full h-10 px-5 font-black uppercase text-[10px] border-primary/30 bg-primary/5 text-primary shadow-none hover:bg-primary/10 tracking-widest transition-all outline-none"
                  >
                    <Box className="mr-2 h-3.5 w-3.5" />
                    School Map
                  </Button>
                )}
                <Button
                  variant="outline"
                  onClick={() => setIsEditModalOpen(true)}
                  className="rounded-full h-10 px-5 font-black uppercase tracking-wider text-[10px] border-border/10 shadow-none hover:bg-primary/5 transition-all"
                >
                  <Pencil className="mr-2 h-4 w-4" />
                  Edit
                </Button>
                <Button
                  variant="outline"
                  onClick={() => setIsSurveyModalOpen(true)}
                  className="rounded-full h-10 px-5 font-black uppercase tracking-wider text-[10px] border-border/10 shadow-none hover:bg-primary/5 transition-all"
                >
                  <ClipboardCheck className="mr-2 h-4 w-4" />
                  Survey
                </Button>
                <Button
                  variant="outline"
                  asChild
                  className="rounded-full h-10 px-5 font-black uppercase tracking-wider text-[10px] border-border/10 shadow-none hover:bg-primary/5 transition-all"
                >
                  <Link to={`/schools/${id}/kmz`}>
                    <Layers className="mr-2 h-4 w-4" />
                    KMZ/KML
                  </Link>
                </Button>
              </div>
            }
          />

          {/* Infrastructure Executive Summary Cards */}
          <div className="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {/* Facility Compliance Rate - Most Prominent */}
            <motion.div
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 0 }}
              whileHover={{ scale: 1.02, y: -5 }}
            >
              <Card className="border-2 border-primary/30 bg-linear-to-br from-primary/10 to-primary/5 dark:from-primary/20 dark:to-primary/10 rounded-3xl shadow-primary/20 transition-all duration-300">
                <CardContent className="p-5">
                  <div className="flex items-center justify-between">
                    <div>
                      <p className="text-[10px] font-black uppercase tracking-widest text-primary/80">
                        Facility Compliance
                      </p>
                      <p className="text-3xl font-black text-primary mt-1">
                        {facilityStats.complianceRate}%
                      </p>
                    </div>
                    <div className="w-12 h-12 bg-primary/30 rounded-2xl flex items-center justify-center">
                      <ClipboardCheck className="w-6 h-6 text-primary" />
                    </div>
                  </div>
                  <div className="mt-3 flex items-center gap-2 text-[10px] text-primary/70">
                    <CheckCircle className="w-3 h-3" />
                    <span>{facilityStats.total} items surveyed</span>
                  </div>
                </CardContent>
              </Card>
            </motion.div>

            {/* Buildings Condition - Infrastructure Focus */}
            <motion.div
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 0.1 }}
              whileHover={{ scale: 1.02, y: -5 }}
            >
              <Card className="border border-border/20 bg-linear-to-br from-emerald-50 to-emerald-100/50 dark:from-emerald-950/30 dark:to-emerald-900/10 rounded-3xl -emerald-500/20 transition-all duration-300">
                <CardContent className="p-5">
                  <div className="flex items-center justify-between">
                    <div>
                      <p className="text-[10px] font-black uppercase tracking-widest text-emerald-600/70">
                        Building Conditions
                      </p>
                      <p className="text-2xl font-black text-emerald-700 dark:text-emerald-300 mt-1">
                        {
                          buildings.filter((b: any) => b.condition === "good")
                            .length
                        }
                        /{buildings.length}
                      </p>
                    </div>
                    <div className="w-12 h-12 bg-emerald-500/20 rounded-2xl flex items-center justify-center">
                      <Building2 className="w-6 h-6 text-emerald-600" />
                    </div>
                  </div>
                  <div className="mt-3 flex items-center gap-2 text-[10px] text-emerald-600/70">
                    <Activity className="w-3 h-3" />
                    <span>
                      Avg Year:{" "}
                      {avgBuildingYear > 0
                        ? avgBuildingYear
                        : schoolData.establishedYear}
                    </span>
                  </div>
                </CardContent>
              </Card>
            </motion.div>

            {/* Infrastructure Score - Most Important */}
            <motion.div
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 0.2 }}
              whileHover={{ scale: 1.02, y: -5 }}
            >
              <Card className="border border-border/20 bg-linear-to-br from-orange-50 to-orange-100/50 dark:from-orange-950/30 dark:to-orange-900/10 rounded-3xl -orange-500/20 transition-all duration-300">
                <CardContent className="p-5">
                  <div className="flex items-center justify-between">
                    <div>
                      <p className="text-[10px] font-black uppercase tracking-widest text-orange-600/70">
                        Infrastructure
                      </p>
                      <p className="text-2xl font-black text-orange-700 dark:text-orange-300 mt-1">
                        {assessment.infrastructureScore ?? 0}%
                      </p>
                    </div>
                    <div className="w-12 h-12 bg-orange-500/20 rounded-2xl flex items-center justify-center">
                      <Zap className="w-6 h-6 text-orange-600" />
                    </div>
                  </div>
                  <div className="mt-3 flex items-center gap-2 text-[10px] text-orange-600/70">
                    <Home className="w-3 h-3" />
                    <span>Facilities & Utilities</span>
                  </div>
                </CardContent>
              </Card>
            </motion.div>

            {/* Priority Level - Infrastructure Risk */}
            <motion.div
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 0.3 }}
              whileHover={{ scale: 1.02, y: -5 }}
            >
              <Card
                className={cn(
                  "border border-border/20 bg-linear-to-br rounded-3xl transition-all duration-300",
                  assessment.priorityLevel === "critical"
                    ? "from-red-50 to-red-100/50 dark:from-red-950/30 dark:to-red-900/10 hover:shadow-red-500/20"
                    : assessment.priorityLevel === "high"
                      ? "from-amber-50 to-amber-100/50 dark:from-amber-950/30 dark:to-amber-900/10 hover:shadow-amber-500/20"
                      : "from-blue-50 to-blue-100/50 dark:from-blue-950/30 dark:to-blue-900/10 hover:shadow-blue-500/20",
                )}
              >
                <CardContent className="p-5">
                  <div className="flex items-center justify-between">
                    <div>
                      <p className="text-[10px] font-black uppercase tracking-widest opacity-70">
                        Infrastructure Risk
                      </p>
                      <div className="mt-1">
                        {getPriorityBadge(assessment.priorityLevel)}
                      </div>
                    </div>
                    <div
                      className={cn(
                        "w-12 h-12 rounded-2xl flex items-center justify-center",
                        assessment.priorityLevel === "critical"
                          ? "bg-red-500/20"
                          : assessment.priorityLevel === "high"
                            ? "bg-amber-500/20"
                            : "bg-blue-500/20",
                      )}
                    >
                      <AlertTriangle
                        className={cn(
                          "w-6 h-6",
                          assessment.priorityLevel === "critical"
                            ? "text-red-600"
                            : assessment.priorityLevel === "high"
                              ? "text-amber-600"
                              : "text-blue-600",
                        )}
                      />
                    </div>
                  </div>
                  <div className="mt-3 flex items-center gap-2 text-[10px] opacity-70">
                    <Wrench className="w-3 h-3" />
                    <span>Maintenance Priority</span>
                  </div>
                </CardContent>
              </Card>
            </motion.div>

          {/* Secondary KPI Cards - Less Prominent */}
          <div className="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {/* Students - Demoted */}
            <motion.div
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 0.4 }}
              whileHover={{ scale: 1.02, y: -5 }}
            >
              <Card className="border border-border/10 bg-linear-to-br from-slate-50 to-slate-100/30 dark:from-slate-950/20 dark:to-slate-900/5 rounded-3xl opacity-80 transition-all duration-300">
                <CardContent className="p-5">
                  <div className="flex items-center justify-between">
                    <div>
                      <p className="text-[9px] font-black uppercase tracking-widest text-slate-600/60">
                        Students
                      </p>
                      <p className="text-xl font-black text-slate-700 dark:text-slate-400 mt-1">
                        {formatNumber(totalStudents)}
                      </p>
                    </div>
                    <div className="w-10 h-10 bg-slate-500/10 rounded-xl flex items-center justify-center">
                      <Users className="w-5 h-5 text-slate-500" />
                    </div>
                  </div>
                  <div className="mt-3 flex items-center gap-2 text-[9px] text-slate-600/60">
                    <TrendingUp className="w-3 h-3" />
                    <span>Capacity: {formatNumber(totalCapacity)}</span>
                  </div>
                </CardContent>
              </Card>
            </motion.div>
            {/* Staff - Demoted */}
            <motion.div
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 0.5 }}
              whileHover={{ scale: 1.02, y: -5 }}
            >
              <Card className="border border-border/10 bg-linear-to-br from-slate-50 to-slate-100/30 dark:from-slate-950/20 dark:to-slate-900/5 rounded-3xl opacity-80 transition-all duration-300">
                <CardContent className="p-5">
                  <div className="flex items-center justify-between">
                    <div>
                      <p className="text-[9px] font-black uppercase tracking-widest text-slate-600/60">
                        Staff
                      </p>
                      <p className="text-xl font-black text-slate-700 dark:text-slate-400 mt-1">
                        {formatNumber(totalStaff)}
                      </p>
                    </div>
                    <div className="w-10 h-10 bg-slate-500/10 rounded-xl flex items-center justify-center">
                      <TeacherIcon className="w-5 h-5 text-slate-500" />
                    </div>
                  </div>
                  <div className="mt-3 flex items-center gap-2 text-[9px] text-slate-600/60">
                    <Target className="w-3 h-3" />
                    <span>
                      Teachers: {totalTeachers}
                    </span>
                  </div>
                </CardContent>
              </Card>
            </motion.div>

            {/* Land Usage - Demoted */}
            <motion.div
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: 0.6 }}
              whileHover={{ scale: 1.02, y: -5 }}
            >
              <Card className="border border-border/10 bg-linear-to-br from-slate-50 to-slate-100/30 dark:from-slate-950/20 dark:to-slate-900/5 rounded-3xl opacity-80 transition-all duration-300">
                <CardContent className="p-5">
                  <div className="flex items-center justify-between">
                    <div>
                      <p className="text-[9px] font-black uppercase tracking-widest text-slate-600/60">
                        Land Usage
                      </p>
                      <p className="text-xl font-black text-slate-700 dark:text-slate-400 mt-1">
                        {schoolData.usedLandArea !== undefined
                          ? `${Math.round(schoolData.usedLandArea)} ha`
                          : "--"}
                      </p>
                    </div>
                    <div className="w-10 h-10 bg-slate-500/10 rounded-xl flex items-center justify-center">
                      <MapPin className="w-5 h-5 text-slate-500" />
                    </div>
                  </div>
                  <div className="mt-3 flex items-center gap-2 text-[9px] text-slate-600/60">
                    <Activity className="w-3 h-3" />
                    <span>
                      Total: {Number(schoolData.usedLandArea || 0) + Number(schoolData.unusedLandArea || 0)} ha
                    </span>
                  </div>
                </CardContent>
              </Card>
            </motion.div>
          </div>

          {/* Main Grid - Infrastructure Focused Layout */}
          <div className="grid grid-cols-1 xl:grid-cols-3 gap-6">
            {/* Left Column - Primary Infrastructure Content (2/3 width) */}
            <div className="xl:col-span-2 space-y-6">
              {/* Facility Survey General Summary - Prominent */}
              <motion.div
                initial={{ opacity: 0, y: 20 }}
                animate={{ opacity: 1, y: 0 }}
                transition={{ delay: 0.3 }}
              >
                <Card className="border-2 border-primary/20 bg-card/60 backdrop-blur-sm rounded-3xl overflow-hidden">
                  <CardHeader className="border-b border-border/10 pb-4">
                    <CardTitle className="text-lg font-bold flex items-center gap-2">
                      <ClipboardCheck className="w-5 h-5 text-primary" />
                      Facility Survey General Summary
                    </CardTitle>
                  </CardHeader>
                  <CardContent className="p-6 space-y-4">
                    {facilityStats.total > 0 ? (
                      <>
                        {/* Large Compliance Rate */}
                        <div className="text-center p-6 bg-primary/10 rounded-2xl">
                          <p className="text-xs font-black uppercase tracking-widest text-primary/70">
                            Overall Compliance Rate
                          </p>
                          <p className="text-5xl font-black text-primary mt-2">
                            {facilityStats.complianceRate}%
                          </p>
                        </div>

                        {/* Three Column Stats */}
                        <div className="grid grid-cols-3 gap-4">
                          <div className="p-4 rounded-xl border-2 bg-emerald-50 dark:bg-emerald-950/20 border-emerald-200 dark:border-emerald-800 text-center">
                            <CheckCircle className="w-6 h-6 text-emerald-600 mx-auto mb-2" />
                            <p className="text-2xl font-black text-emerald-700 dark:text-emerald-400">
                              {facilityStats.compliant}
                            </p>
                            <p className="text-[10px] font-black uppercase text-emerald-600/70">
                              Compliant
                            </p>
                          </div>
                          <div className="p-4 rounded-xl border-2 bg-amber-50 dark:bg-amber-950/20 border-amber-200 dark:border-amber-800 text-center">
                            <AlertTriangle className="w-6 h-6 text-amber-600 mx-auto mb-2" />
                            <p className="text-2xl font-black text-amber-700 dark:text-amber-400">
                              {facilityStats.partial}
                            </p>
                            <p className="text-[10px] font-black uppercase text-amber-600/70">
                              Partial
                            </p>
                          </div>
                          <div className="p-4 rounded-xl border-2 bg-red-50 dark:bg-red-950/20 border-red-200 dark:border-red-800 text-center">
                            <XCircle className="w-6 h-6 text-red-600 mx-auto mb-2" />
                            <p className="text-2xl font-black text-red-700 dark:text-red-400">
                              {facilityStats.nonCompliant}
                            </p>
                            <p className="text-[10px] font-black uppercase text-red-600/70">
                              Non-Compliant
                            </p>
                          </div>
                        </div>

                        {/* Total Items */}
                        <div className="text-center text-sm text-muted-foreground bg-muted/30 p-3 rounded-xl">
                          <span className="font-bold">
                            {facilityStats.total}
                          </span>{" "}
                          facility items surveyed
                        </div>

                        {/* Detailed Facility Breakdown */}
                        {facilityStats.byFacility &&
                          facilityStats.byFacility.length > 0 && (
                            <div className="mt-4 pt-4 border-t border-border/20">
                              <p className="text-xs font-black uppercase tracking-widest text-muted-foreground mb-3">
                                Facility Breakdown
                              </p>
                              <div className="space-y-3 grid grid-cols-2 gap-3">
                                {facilityStats.byFacility.map(
                                  (facilityGroup: any, index: number) => {
                                    const facilityCompliant =
                                      facilityGroup.items.filter(
                                        (i: any) =>
                                          i.compliance === "compliant",
                                      ).length;
                                    const facilityTotal =
                                      facilityGroup.items.length;
                                    const facilityRate =
                                      facilityTotal > 0
                                        ? Math.round(
                                            (facilityCompliant /
                                              facilityTotal) *
                                              100,
                                          )
                                        : 0;

                                    return (
                                      <div
                                        key={index}
                                        className="p-3 rounded-xl bg-muted/30 border border-border/20 mb-0"
                                      >
                                        <div className="flex items-center justify-between">
                                          <span className="text-sm font-bold">
                                            {facilityGroup.facility}
                                          </span>
                                          <span
                                            className={cn(
                                              "text-xs font-black px-2 py-1 rounded-full",
                                              facilityRate >= 70
                                                ? "bg-emerald-500/20 text-emerald-700"
                                                : facilityRate >= 40
                                                  ? "bg-amber-500/20 text-amber-700"
                                                  : "bg-red-500/20 text-red-700",
                                            )}
                                          >
                                            {facilityRate}%
                                          </span>
                                        </div>
                                      </div>
                                    );
                                  },
                                )}
                              </div>
                            </div>
                          )}
                      </>
                    ) : (
                      <div className="text-center py-10 text-muted-foreground">
                        <ClipboardCheck className="w-16 h-16 mx-auto mb-4 opacity-30" />
                        <p className="text-lg font-semibold">
                          No Facility Survey Data
                        </p>
                        <p className="text-sm mt-2 mb-4">
                          Complete a facility survey to see compliance details
                        </p>
                        <Button
                          onClick={() => setIsSurveyModalOpen(true)}
                          className="rounded-full"
                        >
                          Start Facility Survey
                        </Button>
                      </div>
                    )}
                  </CardContent>
                </Card>
              </motion.div>

              {/* Buildings & Infrastructure Status */}
              <motion.div
                initial={{ opacity: 0, x: -20 }}
                animate={{ opacity: 1, x: 0 }}
                transition={{ delay: 0.4 }}
              >
                <Card className="border border-border/20 bg-card/60 backdrop-blur-sm rounded-3xl">
                  <CardHeader className="border-b border-border/10 pb-4">
                    <CardTitle className="text-base font-bold flex items-center gap-2">
                      <Building2 className="w-5 h-5 text-primary" />
                      Buildings & Infrastructure Status
                    </CardTitle>
                  </CardHeader>
                  <CardContent className="p-4">
                    {buildings.length > 0 ? (
                      <div className="space-y-3">
                        {buildings
                          .slice(0, 5)
                          .map((building: any, index: number) => (
                            <div
                              key={index}
                              className="p-3 rounded-xl border bg-muted/30 flex items-center justify-between"
                            >
                              <div>
                                <p className="text-sm font-bold">
                                  {building.name || building.buildingName}
                                </p>
                                <p className="text-xs text-muted-foreground">
                                  {building.function ||
                                    building.buildingFunction}
                                </p>
                              </div>
                              <Badge
                                className={cn(
                                  "rounded-full font-black text-xs",
                                  building.condition === "good"
                                    ? "bg-emerald-500/20 text-emerald-700"
                                    : building.condition === "fair"
                                      ? "bg-amber-500/20 text-amber-700"
                                      : "bg-red-500/20 text-red-700",
                                )}
                              >
                                {building.condition}
                              </Badge>
                            </div>
                          ))}
                        {buildings.length > 5 && (
                          <p className="text-center text-xs text-muted-foreground">
                            + {buildings.length - 5} more buildings
                          </p>
                        )}
                      </div>
                    ) : (
                      <p className="text-center text-muted-foreground py-4">
                        No building data available
                      </p>
                    )}
                  </CardContent>
                </Card>
              </motion.div>

              {/* Facilities Availability */}
              <motion.div
                initial={{ opacity: 0, x: -20 }}
                animate={{ opacity: 1, x: 0 }}
                transition={{ delay: 0.5 }}
              >
                <Card className="border border-border/20 bg-card/60 backdrop-blur-sm rounded-3xl">
                  <CardHeader className="border-b border-border/10 pb-4">
                    <CardTitle className="text-base font-bold flex items-center gap-2">
                      <Home className="w-5 h-5 text-primary" />
                      Facilities Availability
                    </CardTitle>
                  </CardHeader>
                  <CardContent className="p-4">
                    <div className="grid grid-cols-2 gap-3">
                      {[
                        { name: "Library", icon: BookOpen, key: "hasLibrary" },
                        {
                          name: "Laboratory",
                          icon: FlaskConical,
                          key: "hasLaboratory",
                        },
                        {
                          name: "Computer Lab",
                          icon: Monitor,
                          key: "hasComputerLab",
                        },
                        {
                          name: "Sports Field",
                          icon: Trophy,
                          key: "hasSportsField",
                        },
                        { name: "Hostel", icon: Home, key: "hasHostel" },
                        { name: "Canteen", icon: Utensils, key: "hasCanteen" },
                      ].map((facility) => {
                        const hasIt = schoolData[facility.key];
                        return (
                          <div
                            key={facility.key}
                            className={cn(
                              "p-3 rounded-xl border flex items-center gap-3",
                              hasIt
                                ? "bg-emerald-50 border-emerald-200"
                                : "bg-muted/30 border-border",
                            )}
                          >
                            <div
                              className={cn(
                                "w-8 h-8 rounded-lg flex items-center justify-center",
                                hasIt ? "bg-emerald-500/20" : "bg-muted",
                              )}
                            >
                              {hasIt ? (
                                <CheckCircle className="w-4 h-4 text-emerald-600" />
                              ) : (
                                <XCircle className="w-4 h-4 text-muted-foreground" />
                              )}
                            </div>
                            <span
                              className={cn(
                                "text-sm font-bold",
                                hasIt
                                  ? "text-emerald-700"
                                  : "text-muted-foreground",
                              )}
                            >
                              {facility.name}
                            </span>
                          </div>
                        );
                      })}
                    </div>
                  </CardContent>
                </Card>
              </motion.div>

              {/* Utilities & Connectivity */}
              <motion.div
                initial={{ opacity: 0, x: -20 }}
                animate={{ opacity: 1, x: 0 }}
                transition={{ delay: 0.6 }}
              >
                <Card className="border border-border/20 bg-card/60 backdrop-blur-sm rounded-3xl">
                  <CardHeader className="border-b border-border/10 pb-4">
                    <CardTitle className="text-base font-bold flex items-center gap-2">
                      <Zap className="w-5 h-5 text-primary" />
                      Utilities & Connectivity
                    </CardTitle>
                  </CardHeader>
                  <CardContent className="p-4">
                    <div className="space-y-3">
                      {[
                        {
                          name: "Electricity",
                          icon: Zap,
                          key: "hasElectricity",
                        },
                        {
                          name: "Water Supply",
                          icon: Droplets,
                          key: "hasWater",
                        },
                        { name: "Internet", icon: Wifi, key: "hasInternet" },
                        {
                          name: "Solar Panels",
                          icon: Sun,
                          key: "hasSolarPanel",
                        },
                      ].map((utility) => {
                        const hasIt = schoolData[utility.key];
                        return (
                          <div
                            key={utility.key}
                            className={cn(
                              "p-3 rounded-xl border flex items-center gap-3",
                              hasIt
                                ? "bg-emerald-50 border-emerald-200"
                                : "bg-muted/30 border-border",
                            )}
                          >
                            <div
                              className={cn(
                                "w-8 h-8 rounded-lg flex items-center justify-center",
                                hasIt ? "bg-emerald-500/20" : "bg-muted",
                              )}
                            >
                              {hasIt ? (
                                <CheckCircle className="w-4 h-4 text-emerald-600" />
                              ) : (
                                <XCircle className="w-4 h-4 text-muted-foreground" />
                              )}
                            </div>
                            <span
                              className={cn(
                                "text-sm font-bold",
                                hasIt
                                  ? "text-emerald-700"
                                  : "text-muted-foreground",
                              )}
                            >
                              {utility.name}
                            </span>
                          </div>
                        );
                      })}
                    </div>
                  </CardContent>
                </Card>
              </motion.div>
            </div>

            {/* Right Column - Secondary Information (1/3 width) */}
            <div className="space-y-6">
              {/* Decision Intelligence Score - Infrastructure Focused */}
              <motion.div
                initial={{ opacity: 0, x: -20 }}
                animate={{ opacity: 1, x: 0 }}
                transition={{ delay: 0.4 }}
              >
                <Card className="border border-border/20 bg-card/60 backdrop-blur-sm rounded-3xl overflow-hidden">
                  <CardHeader className="border-b border-border/10 pb-4">
                    <CardTitle className="text-base font-bold flex items-center gap-2">
                      <Activity className="w-5 h-5 text-primary" />
                      Infrastructure Score
                    </CardTitle>
                  </CardHeader>
                  <CardContent className="p-6">
                    <div className="grid grid-cols-1 gap-4">
                      {/* Infrastructure Score - Large Display */}
                      <div className="text-center p-6 bg-primary/10 rounded-2xl">
                        <p className="text-xs font-black uppercase tracking-widest text-primary/70">
                          Infrastructure Score
                        </p>
                        <p className="text-5xl font-black text-primary mt-2">
                          {assessment.infrastructureScore ?? 0}%
                        </p>
                        <p className="text-xs text-primary/60 mt-2">
                          Based on facilities & utilities
                        </p>
                      </div>

                      {/* Building Condition Score */}
                      <div className="text-center p-4 bg-muted/30 rounded-2xl">
                        <div className="relative w-16 h-16 mx-auto mb-3">
                          <svg className="w-full h-full transform -rotate-90">
                            <circle
                              cx="32"
                              cy="32"
                              r="28"
                              stroke="currentColor"
                              strokeWidth="4"
                              fill="none"
                              className="text-muted/20"
                            />
                            <circle
                              cx="32"
                              cy="32"
                              r="28"
                              stroke="currentColor"
                              strokeWidth="4"
                              fill="none"
                              strokeDasharray={`${((assessment.buildingAgeScore ?? 50) / 100) * 176} 176`}
                              className={cn(
                                "transition-all duration-1000",
                                (assessment.buildingAgeScore ?? 50) >= 70
                                  ? "text-emerald-500"
                                  : (assessment.buildingAgeScore ?? 50) >= 50
                                    ? "text-amber-500"
                                    : "text-red-500",
                              )}
                            />
                          </svg>
                          <div className="absolute inset-0 flex items-center justify-center">
                            <span className="text-lg font-black">
                              {assessment.buildingAgeScore ?? 50}
                            </span>
                          </div>
                        </div>
                        <p className="text-xs font-bold text-muted-foreground">
                          Building Condition
                        </p>
                      </div>
                    </div>

                    {/* Recommendations */}
                    <div className="mt-6 p-4 bg-amber-50 dark:bg-amber-950/20 border border-amber-100 dark:border-amber-900/30 rounded-2xl">
                      <h4 className="text-sm font-bold text-amber-800 dark:text-amber-400 flex items-center gap-2 mb-3">
                        <Wrench className="w-4 h-4" />
                        System Recommendations
                      </h4>
                      <ul className="space-y-2">
                        {assessment.recommendations?.map(
                          (rec: string, i: number) => (
                            <li
                              key={i}
                              className="text-sm text-amber-900 dark:text-amber-300 flex items-start gap-2"
                            >
                              <ChevronRight className="w-4 h-4 mt-0.5 shrink-0" />
                              {rec}
                            </li>
                          ),
                        )}
                      </ul>
                    </div>
                  </CardContent>
                </Card>
              </motion.div>

              {/* Student Distribution - Secondary Content */}
              <motion.div
                initial={{ opacity: 0, x: -20 }}
                animate={{ opacity: 1, x: 0 }}
                transition={{ delay: 0.5 }}
              >
                <Card className="border border-border/20 bg-card/60 backdrop-blur-sm rounded-3xl">
                  <CardHeader className="border-b border-border/10 pb-4">
                    <CardTitle className="text-base font-bold flex items-center gap-2">
                      <GraduationCap className="w-5 h-5 text-primary" />
                      Student Distribution
                    </CardTitle>
                  </CardHeader>
                  <CardContent className="p-4">
                    {schoolData.educationPrograms &&
                    schoolData.educationPrograms.length > 0 ? (
                      <div className="space-y-3">
                        <div className="text-center p-4 bg-muted/30 rounded-2xl">
                          <p className="text-3xl font-black">
                            {formatNumber(totalStudents)}
                          </p>
                          <p className="text-xs font-bold text-muted-foreground">
                            Total Students
                          </p>
                        </div>
                        <div className="space-y-2">
                          {schoolData.educationPrograms.slice(0, 3).map(
                            (program: any, index: number) => (
                              <div
                                key={program.code || index}
                                className="p-3 rounded-xl border bg-muted/30 flex items-center justify-between"
                              >
                                <span className="text-sm font-bold truncate">
                                  {program.name || program.code}
                                </span>
                                <span className="text-xs text-muted-foreground">
                                  {program.totalStudents || 0}
                                </span>
                              </div>
                            ),
                          )}
                        </div>
                        {schoolData.educationPrograms.length > 3 && (
                          <p className="text-center text-xs text-muted-foreground">
                            + {schoolData.educationPrograms.length - 3} more programs
                          </p>
                        )}
                      </div>
                    ) : (
                      <div className="text-center py-8 text-muted-foreground">
                        <p className="text-sm">No trades available</p>
                        <p className="text-xs mt-1">
                          Add programs to see student distribution
                        </p>
                      </div>
                    )}

                    {/* Show total summary */}
                    {schoolData.educationPrograms &&
                      schoolData.educationPrograms.length > 0 && (
                        <div className="mt-4 pt-4 border-t border-border/10 flex justify-between items-center">
                          <div>
                            <p className="text-xs font-bold text-muted-foreground">
                              Total Students
                            </p>
                            <p className="text-2xl font-black">
                              {formatNumber(
                                schoolData.calculatedAssessment
                                  ?.totalStudents ||
                                  schoolData.educationPrograms.reduce(
                                    (sum: number, p: any) =>
                                      sum + (p.totalStudents || 0),
                                    0,
                                  ),
                              )}
                            </p>
                          </div>
                          <div className="text-right">
                            <p className="text-xs font-bold text-muted-foreground">
                              Total Capacity
                            </p>
                            <p className="text-2xl font-black">
                              {formatNumber(
                                schoolData.calculatedAssessment
                                  ?.totalCapacity ||
                                  schoolData.educationPrograms.reduce(
                                    (sum: number, p: any) =>
                                      sum + (p.capacity || 0),
                                    0,
                                  ),
                              )}
                            </p>
                          </div>
                        </div>
                      )}
                  </CardContent>
                </Card>
              </motion.div>

              {/* Location & Contact - Secondary */}
              <motion.div
                initial={{ opacity: 0, x: -20 }}
                animate={{ opacity: 1, x: 0 }}
                transition={{ delay: 0.6 }}
              >
                <Card className="border border-border/20 bg-card/60 backdrop-blur-sm rounded-3xl">
                  <CardHeader className="border-b border-border/10 pb-4">
                    <CardTitle className="text-base font-bold flex items-center gap-2">
                      <MapPin className="w-5 h-5 text-primary" />
                      Location & Contact
                    </CardTitle>
                  </CardHeader>
                  <CardContent className="p-4 space-y-3">
                    <div className="grid grid-cols-2 gap-2 text-xs">
                      <div className="flex items-center justify-between bg-muted/30 rounded-lg px-3 py-2">
                        <span className="text-muted-foreground">Latitude</span>
                        <span className="font-mono font-bold text-xs">
                          {Number(schoolData.latitude).toFixed(4)}
                        </span>
                      </div>
                      <div className="flex items-center justify-between bg-muted/30 rounded-lg px-3 py-2">
                        <span className="text-muted-foreground">Longitude</span>
                        <span className="font-mono font-bold text-xs">
                          {Number(schoolData.longitude).toFixed(4)}
                        </span>
                      </div>
                    </div>
                    <div className="flex items-center gap-3 p-3 bg-muted/30 rounded-xl">
                      <div className="w-8 h-8 bg-primary/10 rounded-lg flex items-center justify-center">
                        <Phone className="w-4 h-4 text-primary" />
                      </div>
                      <div>
                        <p className="text-[10px] font-black uppercase text-muted-foreground">
                          Contact
                        </p>
                        <p className="text-sm font-bold">{schoolData.phone}</p>
                      </div>
                    </div>
                  </CardContent>
                </Card>
              </motion.div>
            </div>
          </div>

          {/* 3D View Modal - Ultra Rich Space Design */}
          {is3DViewOpen && (
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              className="fixed inset-0 z-50 bg-black/95 flex items-center justify-center p-4"
            >
              {/* Ultra Rich Animated Space Background */}
              <div className="absolute inset-0 overflow-hidden">
                {/* Deep Space linear */}
                <div className="absolute inset-0 bg-[radial-linear(ellipse_at_center,var(--tw-linear-stops))] from-slate-950 via-blue-950/40 to-black"></div>

                {/* Nebula Effect 1 */}
                <div className="absolute top-1/4 left-1/4 w-96 h-96 bg-blue-600/20 rounded-full blur-[100px] animate-pulse"></div>

                {/* Nebula Effect 2 */}
                <div
                  className="absolute bottom-1/4 right-1/4 w-80 h-80 bg-fuchsia-600/15 rounded-full blur-[80px] animate-pulse"
                  style={{ animationDelay: "1s" }}
                ></div>

                {/* Nebula Effect 3 */}
                <div
                  className="absolute top-1/2 right-1/3 w-64 h-64 bg-blue-600/10 rounded-full blur-[60px] animate-pulse"
                  style={{ animationDelay: "2s" }}
                ></div>

                {/* Stars - Layer 1 (Small) */}
                {[...Array(80)].map((_, i) => (
                  <div
                    key={`small-${i}`}
                    className="absolute bg-white rounded-full animate-pulse"
                    style={{
                      left: `${Math.random() * 100}%`,
                      top: `${Math.random() * 100}%`,
                      width: `${Math.random() * 1.5 + 0.5}px`,
                      height: `${Math.random() * 1.5 + 0.5}px`,
                      animationDelay: `${Math.random() * 4}s`,
                      animationDuration: `${Math.random() * 2 + 2}s`,
                      opacity: Math.random() * 0.7 + 0.3,
                    }}
                  />
                ))}

                {/* Stars - Layer 2 (Medium with glow) */}
                {[...Array(30)].map((_, i) => (
                  <div
                    key={`medium-${i}`}
                    className="absolute rounded-full animate-pulse"
                    style={{
                      left: `${Math.random() * 100}%`,
                      top: `${Math.random() * 100}%`,
                      width: `${Math.random() * 2 + 2}px`,
                      height: `${Math.random() * 2 + 2}px`,
                      animationDelay: `${Math.random() * 3}s`,
                      animationDuration: `${Math.random() * 3 + 2}s`,
                      boxShadow: `0 0 ${Math.random() * 4 + 2}px ${Math.random() * 2 + 1}px rgba(255,255,255,0.8)`,
                      background:
                        "radial-linear(circle, white 0%, rgba(255,255,255,0.5) 50%, transparent 100%)",
                    }}
                  />
                ))}

                {/* Shooting Stars */}
                {[...Array(5)].map((_, i) => (
                  <div
                    key={`shooting-${i}`}
                    className="absolute w-1 h-1 bg-white rounded-full animate-ping"
                    style={{
                      left: `${10 + i * 20}%`,
                      top: `${5 + i * 15}%`,
                      animationDelay: `${i * 2}s`,
                      animationDuration: "3s",
                      boxShadow: "0 0 6px 2px rgba(255,255,255,0.8)",
                    }}
                  />
                ))}

                {/* Floating Particles */}
                {[...Array(15)].map((_, i) => (
                  <div
                    key={`particle-${i}`}
                    className="absolute w-0.5 h-0.5 bg-blue-400 rounded-full animate-bounce"
                    style={{
                      left: `${Math.random() * 100}%`,
                      top: `${Math.random() * 100}%`,
                      animationDelay: `${Math.random() * 5}s`,
                      animationDuration: `${Math.random() * 4 + 4}s`,
                      opacity: 0.6,
                    }}
                  />
                ))}
              </div>

              <motion.div
                initial={{ scale: 0.9, opacity: 0 }}
                animate={{ scale: 1, opacity: 1 }}
                transition={{ duration: 0.5, ease: "easeOut" }}
                className="relative w-full max-w-6xl h-[85vh] rounded-3xl overflow-hidden border border-white/20 shadow-2xl bg-linear-to-br from-slate-900/80 to-blue-950/30 backdrop-blur-sm"
              >
                {/* Animated Border Glow */}
                <div className="absolute inset-0 rounded-3xl border-2 border-white/10 animate-pulse"></div>
                <div
                  className="absolute inset-0 rounded-3xl border border-blue-500/20"
                  style={{
                    boxShadow:
                      "0 0 30px rgba(139, 92, 246, 0.3), inset 0 0 30px rgba(139, 92, 246, 0.1)",
                  }}
                ></div>
                {/* Main Content */}
                <div className="absolute inset-0 flex items-center justify-center">
                  {id && (
                    <img
                      src={`/public/uploads/schools/${id}/kmz_content/b0.png`}
                      alt="School Structure"
                      className="max-w-full max-h-full object-contain p-8 drop-shadow-2xl"
                      onError={(e) => {
                        const img = e.target as HTMLImageElement;
                        img.src = `/public/uploads/schools/${id}/kmz_content/a.png`;
                      }}
                    />
                  )}
                </div>

                {/* Floating 3D View Button */}
                <div className="absolute bottom-8 right-8 z-20">
                  <Button
                    size="lg"
                    className="rounded-full px-10 py-7 bg-linear-to-r from-blue-600 via-blue-600 to-blue-600 hover:from-blue-700 hover:via-blue-700 hover:to-blue-700 text-white font-bold text-lg shadow-2xl shadow-blue-500/40 hover:shadow-blue-500/60 transition-all duration-300 transform hover:scale-110"
                    onClick={() => navigate(`/schools/${id}/3dview`)}
                  >
                    <Box className="w-6 h-6 mr-3" />
                    Open School Map
                  </Button>
                </div>

                {/* School Info Badge */}
                <div className="absolute top-6 left-6 z-20">
                  <div className="bg-black/70 backdrop-blur-xl rounded-2xl px-6 py-3 border border-white/20 shadow-lg">
                    <p className="text-white font-bold text-lg">
                      {schoolData.name}
                    </p>
                    <p className="text-blue-300 text-sm font-medium">
                      {schoolData.code}
                    </p>
                  </div>
                </div>

                {/* Close Button */}
                <button
                  onClick={() => setIs3DViewOpen(false)}
                  className="absolute top-6 right-6 z-30 bg-white/10 hover:bg-white/20 backdrop-blur-md rounded-full p-3 transition-all duration-300 hover:rotate-90"
                >
                  <XCircle className="w-8 h-8 text-white" />
                </button>

                {/* Bottom Stats */}
                <div className="absolute bottom-6 left-6 z-20 flex gap-4">
                  <div className="bg-black/50 backdrop-blur-md rounded-xl px-4 py-2 border border-white/10">
                    <p className="text-white/60 text-xs">Students</p>
                    <p className="text-white font-bold">
                      {formatNumber(totalStudents)}
                    </p>
                  </div>
                  <div className="bg-black/50 backdrop-blur-md rounded-xl px-4 py-2 border border-white/10">
                    <p className="text-white/60 text-xs">Teachers</p>
                    <p className="text-white font-bold">
                      {formatNumber(totalStaff)}
                    </p>
                  </div>
                  <div className="bg-black/50 backdrop-blur-md rounded-xl px-4 py-2 border border-white/10">
                    <p className="text-white/60 text-xs">Buildings</p>
                    <p className="text-white font-bold">{buildings.length}</p>
                  </div>
                </div>
              </motion.div>
            </motion.div>
          )}

          {/* EDIT SCHOOL MODAL */}
          <SchoolForm
            isOpen={isEditModalOpen}
            onClose={() => setIsEditModalOpen(false)}
            onSuccess={() => {
              setIsEditModalOpen(false);
              // Refetch school data after edit
              if (id) {
                api.get(`/schools/${id}`).then((res) => setSchool(res.data));
              }
            }}
            mode="edit"
            schoolId={id}
            initialData={schoolData}
          />
        </div>
      )}
      {/* FACILITY SURVEY MODAL */}
      {isSurveyModalOpen && (
        <FacilitySurveyForm
          schoolId={id!}
          schoolName={school?.name || ""}
          isOpen={isSurveyModalOpen}
          onClose={() => setIsSurveyModalOpen(false)}
        />
      )}
    </>
  );
}
